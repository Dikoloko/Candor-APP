# Supabase instellen voor gedeeld leaderboard (optioneel)
# 1. Maak een gratis project aan op https://supabase.com
# 2. Voer dit SQL uit in de Supabase SQL Editor:
#
#    CREATE TABLE leaderboard (
#      id bigint generated always as identity primary key,
#      naam text not null,
#      score integer not null,
#      totaal integer not null,
#      punten integer not null default 0,
#      max_punten integer not null default 0,
#      datum timestamptz default now()
#    );
#    ALTER TABLE leaderboard ENABLE ROW LEVEL SECURITY;
#    CREATE POLICY "Iedereen kan lezen" ON leaderboard FOR SELECT USING (true);
#    CREATE POLICY "Iedereen kan toevoegen" ON leaderboard FOR INSERT WITH CHECK (true);
#
# 3. Kopieer Project URL en anon key vanuit Project Settings > API
# 4. Voeg toe in Netlify: Site settings > Environment variables

VITE_SUPABASE_URL=https://jouw-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-anon-key-hier
